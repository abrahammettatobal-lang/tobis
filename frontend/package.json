{
  "name": "tobalazo-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-icons.mjs && vite build && node scripts/patch-en-vivo.mjs",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "cap:assets": "npx @capacitor/assets generate --iconBackgroundColor \"#121212\" --splashBackgroundColor \"#121212\" --assetPath assets --android --ios",
    "build:app": "npm run build && cap sync",
    "cap:sync": "cap sync",
    "cap:add:android": "cap add android",
    "cap:android": "cap open android",
    "apk:build": "powershell -ExecutionPolicy Bypass -File ./scripts/build-apk.ps1",
    "apk:github": "gh workflow run android-apk.yml"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/splash-screen": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "sharp": "^0.34.2",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^0.21.2"
  }
}
