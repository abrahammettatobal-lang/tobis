PORT=3001
API_DAILY_LIMIT=100
SCRAPE_INTERVAL_MS=60000
FRONTEND_URL=http://localhost:5173,https://tobis-two.vercel.app
LIVESCORE_LOCALE=en

# Flashscore (RapidAPI) — https://rapidapi.com (flashscore4)
RAPIDAPI_KEY=your_rapidapi_key_here

# SportsAPIPro V4 — fallback si no hay RAPIDAPI_KEY
SPORTSAPI_KEY=your_api_key_here

# Fallback opcional (api-sports.io)
APISPORTS_KEY=

# Transmisión en vivo (Gemini busca directos en YouTube)
GEMINI_API_KEY=
# Opcional: verifica que el video siga en vivo
YOUTUBE_API_KEY=

# Railway inyecta automaticamente:
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PUBLIC_DOMAIN=tobis-backend-production.up.railway.app
